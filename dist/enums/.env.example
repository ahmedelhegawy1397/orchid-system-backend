PORT=5000

# Database
# Local: mongodb://localhost:27017/orchid-dental
# Atlas: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/orchid-dental?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/orchid-dental

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Clinic Settings
CLINIC_TIMEZONE=Africa/Cairo
WORKDAY_START_HOUR=6

# CORS (optional - defaults to allow all in development)
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173
